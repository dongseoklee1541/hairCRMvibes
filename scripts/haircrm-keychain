#!/bin/zsh -f

emulate -LR zsh
unsetopt XTRACE VERBOSE
setopt ERR_EXIT NO_UNSET PIPE_FAIL
umask 077
ulimit -c 0 2>/dev/null || true

readonly SECURITY_BIN='/usr/bin/security'
readonly GREP_BIN='/usr/bin/grep'
readonly CURL_BIN='/usr/bin/curl'
readonly CAT_BIN='/bin/cat'
readonly OPENSSL_BIN='/usr/bin/openssl'
readonly MKTEMP_BIN='/usr/bin/mktemp'
readonly UNLINK_BIN='/bin/unlink'
readonly PSQL_BIN='/opt/homebrew/opt/postgresql@17/bin/psql'
readonly LOGIN_KEYCHAIN="$HOME/Library/Keychains/login.keychain-db"
readonly SUPABASE_CA_SHA256='807025ad50d4ed219d2c9c7d299c004f824eb00cf7f65afef607d07b72e6cafa'
readonly PROD_DB_CONNINFO='host=aws-1-ap-northeast-2.pooler.supabase.com port=5432 user=postgres.skcujebqxjvmzmaiddvb dbname=postgres sslmode=verify-full require_auth=scram-sha-256 passfile=/dev/null connect_timeout=10'

typeset -g TARGET_ALIAS=''
typeset -g TARGET_SERVICE=''
typeset -g TARGET_ACCOUNT=''
typeset -g SECRET_VALUE=''
typeset -g TEMP_CA_FILE=''
typeset -g TEMP_HTTP_BODY=''
typeset -g TEMP_STORE_SERVICE=''
typeset -g TEMP_STORE_ACCOUNT=''
typeset -g TEMP_STORE_MARKER=''
typeset -gi TEMP_STORE_CREATED=0

usage() {
  cat <<'USAGE'
Usage:
  scripts/haircrm-keychain status <alias>
  scripts/haircrm-keychain store <alias>
  scripts/haircrm-keychain probe <alias> [--repeat 1..10]
  scripts/haircrm-keychain delete <alias> --confirm <alias>
  scripts/haircrm-keychain db-probe
  scripts/haircrm-keychain cron-request <approved Vercel URL>
  scripts/haircrm-keychain self-test

Aliases:
  prod-db
  vercel-cron
  r07-temp:<run-id>:<slot>

R-07 slots:
  owner-email, owner-password, staff-email, staff-password,
  supabase-secret-key
USAGE
}

die() {
  print -u2 -r -- "error: $*"
  exit 2
}

clear_secret() {
  SECRET_VALUE=''
  unset SECRET_VALUE
  typeset -g SECRET_VALUE=''
}

cleanup_temp_ca() {
  if [[ -n "$TEMP_CA_FILE" && -e "$TEMP_CA_FILE" ]]; then
    "$UNLINK_BIN" "$TEMP_CA_FILE" >/dev/null 2>&1 || return 1
  fi
  TEMP_CA_FILE=''
}

cleanup_temp_http_body() {
  if [[ -n "$TEMP_HTTP_BODY" && -e "$TEMP_HTTP_BODY" ]]; then
    "$UNLINK_BIN" "$TEMP_HTTP_BODY" >/dev/null 2>&1 || return 1
  fi
  TEMP_HTTP_BODY=''
}

cleanup_temp_store() {
  local lookup_exit=0
  clear_secret
  if (( TEMP_STORE_CREATED == 1 )); then
    if "$SECURITY_BIN" find-generic-password \
      -s "$TEMP_STORE_SERVICE" \
      -a "$TEMP_STORE_ACCOUNT" \
      -j "$TEMP_STORE_MARKER" \
      "$LOGIN_KEYCHAIN" >/dev/null 2>&1; then
      "$SECURITY_BIN" delete-generic-password \
        -s "$TEMP_STORE_SERVICE" \
        -a "$TEMP_STORE_ACCOUNT" \
        -j "$TEMP_STORE_MARKER" \
        "$LOGIN_KEYCHAIN" >/dev/null 2>&1 || return 1

      if "$SECURITY_BIN" find-generic-password \
        -s "$TEMP_STORE_SERVICE" \
        -a "$TEMP_STORE_ACCOUNT" \
        -j "$TEMP_STORE_MARKER" \
        "$LOGIN_KEYCHAIN" >/dev/null 2>&1; then
        return 1
      else
        lookup_exit=$?
        (( lookup_exit == 44 )) || return 1
      fi
    else
      lookup_exit=$?
      (( lookup_exit == 44 )) || return 1
    fi
  fi
  TEMP_STORE_SERVICE=''
  TEMP_STORE_ACCOUNT=''
  TEMP_STORE_MARKER=''
  TEMP_STORE_CREATED=0
}

TRAPEXIT() {
  cleanup_temp_store || print -u2 -r -- 'error: exact Keychain rollback cleanup failed'
  cleanup_temp_http_body || print -u2 -r -- 'error: temporary Cron response cleanup failed'
  cleanup_temp_ca || print -u2 -r -- 'error: temporary Supabase CA cleanup failed'
}

TRAPINT() { exit 130 }
TRAPTERM() { exit 143 }
TRAPHUP() { exit 129 }

